{
  "name": "shiplocal",
  "version": "0.0.1",
  "description": "Share localhost with clients in seconds",
  "type": "module",
  "bin": {
    "shiplocal": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src/",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@shiplocal/shared": "workspace:*",
    "@shiplocal/tunnel-client": "workspace:*",
    "commander": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
