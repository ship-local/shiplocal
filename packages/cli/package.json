{
  "name": "shiplocal",
  "version": "0.1.0",
  "description": "Share localhost with clients in seconds",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ship-local/shiplocal.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/ship-local/shiplocal#readme",
  "bugs": {
    "url": "https://github.com/ship-local/shiplocal/issues"
  },
  "keywords": [
    "tunnel",
    "localhost",
    "ngrok",
    "devtools",
    "preview",
    "feedback"
  ],
  "bin": {
    "shiplocal": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src/",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@shiplocal/shared": "workspace:*",
    "@shiplocal/tunnel-client": "workspace:*",
    "commander": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  }
}
