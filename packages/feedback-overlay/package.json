{
  "name": "@shiplocal/feedback-overlay",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --format=iife --global-name=ShipLocalFeedback --outfile=dist/overlay.js --minify",
