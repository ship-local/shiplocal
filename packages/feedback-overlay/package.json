    "lint": "eslint src/",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "html2canvas": "^1.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "esbuild": "^0.25.5",
    "typescript": "^5.8.3"
  }
}
