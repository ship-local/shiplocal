# Copy to apps/dashboard/.env.local
# cp apps/dashboard/.env.example apps/dashboard/.env.local

NEXT_PUBLIC_API_URL=http://localhost:4000

# Marketing site (landing + blog) and app subdomain (auth + dashboard)
# NEXT_PUBLIC_SITE_URL=https://shiplocal.cloud
# NEXT_PUBLIC_APP_URL=https://app.shiplocal.cloud

# core = hide feedback UI | cloud = full dashboard (match server SHIPLOCAL_EDITION)
NEXT_PUBLIC_SHIPLOCAL_EDITION=cloud

# Google OAuth is configured on the server (apps/server/.env)
