generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String?
  passwordHash String?
  image        String?
  createdAt    DateTime   @default(now())
  projects     Project[]
  apiTokens    ApiToken[]
}

model ApiToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  prefix    String
  name      String    @default("CLI")
  lastUsed  DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model Project {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  tunnels   Tunnel[]

  @@index([userId])
}

model Tunnel {
  id           String       @id @default(cuid())
  projectId    String
  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name         String       @default("web")
  subdomain    String       @unique
  port         Int
  status       TunnelStatus @default(OFFLINE)
  passwordHash String?
  createdAt    DateTime     @default(now())
  expiresAt    DateTime?
  comments     Comment[]

  @@unique([projectId, name])
  @@index([projectId])
}

enum TunnelStatus {
  ONLINE
  OFFLINE
  EXPIRED
}

model Comment {
  id         String   @id @default(cuid())
  tunnelId   String
  tunnel     Tunnel   @relation(fields: [tunnelId], references: [id], onDelete: Cascade)
  page       String
  selector   String?
  x          Float?
  y          Float?
  message    String
  screenshot String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([tunnelId])
}
