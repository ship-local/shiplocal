# Copy to apps/server/.env for local development
# cp apps/server/.env.example apps/server/.env

# PostgreSQL (matches docker/docker-compose.yml)
DATABASE_URL="postgresql://shiplocal:shiplocal@localhost:5433/shiplocal?schema=public"

# Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
JWT_SECRET=change-me-in-production

# Optional — used in later phases
REDIS_URL=redis://localhost:6379
SHIPLOCAL_DOMAIN=shiplocal.app

# Cloud storage (Phase 3+)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY=
# R2_SECRET_KEY=
# R2_BUCKET=
