# Copy to apps/server/.env for local development
# cp apps/server/.env.example apps/server/.env

# PostgreSQL (matches docker/docker-compose.yml)
DATABASE_URL="postgresql://shiplocal:shiplocal@localhost:5433/shiplocal?schema=public"

# Server
PORT=4000
HOST=0.0.0.0
NODE_ENV=development
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32
DASHBOARD_URL=http://localhost:3001
API_PUBLIC_URL=http://localhost:4000

# Production example:
# NODE_ENV=production
# SHIPLOCAL_DOMAIN=shiplocal.app
# API_PUBLIC_URL=https://shiplocal.app
# DASHBOARD_URL=https://app.shiplocal.app

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional — used in later phases
REDIS_URL=redis://localhost:6379
SHIPLOCAL_DOMAIN=localhost

# Tunnel expiry in hours (default: 2)
TUNNEL_EXPIRY_HOURS=2

# Cloud storage (Phase 3+)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY=
# R2_SECRET_KEY=
# R2_BUCKET=
