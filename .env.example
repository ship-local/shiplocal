# ShipLocal — environment variables
# See package-specific .env.example files for copy instructions.

# Server → apps/server/.env
DATABASE_URL=postgresql://shiplocal:shiplocal@localhost:5433/shiplocal?schema=public
PORT=4000
JWT_SECRET=change-me-in-production
REDIS_URL=redis://localhost:6379
SHIPLOCAL_DOMAIN=shiplocal.app

# Dashboard → apps/dashboard/.env.local
NEXT_PUBLIC_API_URL=http://localhost:4000

# CLI
SHIPLOCAL_API_URL=http://localhost:4000
SHIPLOCAL_TOKEN=
