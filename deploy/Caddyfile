# ShipLocal production — replace email and domains if needed.
# Wildcard TLS requires Cloudflare DNS challenge on the Caddy build.

{
	email kenny@shiplocal.cloud
}

(tls_cloudflare) {
	tls {
		dns cloudflare {env.CF_API_TOKEN}
	}
}

# Dashboard (auth, tunnels, feedback inbox)
app.shiplocal.cloud {
	import tls_cloudflare
	reverse_proxy 127.0.0.1:3001
}

# Marketing site on apex — API paths still hit the server
shiplocal.cloud {
	import tls_cloudflare

	handle /api/* {
		reverse_proxy 127.0.0.1:4000
	}
	handle /health {
		reverse_proxy 127.0.0.1:4000
	}
	handle /overlay.js {
		reverse_proxy 127.0.0.1:4000
	}
	handle /html2canvas.js {
		reverse_proxy 127.0.0.1:4000
	}
	handle /tunnel {
		reverse_proxy 127.0.0.1:4000
	}
	handle {
		reverse_proxy 127.0.0.1:3001
	}
}

# Tunnel previews (wildcard subdomains)
*.shiplocal.cloud {
	import tls_cloudflare
	reverse_proxy 127.0.0.1:4000
}
